#!/bin/bash
# Opens a searchable neovim cheatsheet in a floating terminal via fzf

DATA="${XDG_DATA_HOME:-$HOME/.local/share}/nvim-cheatsheet.txt"

generate() {
  local R=$'\033[0m'
  local C=$'\033[1;36m'
  local K=$'\033[1;33m'

  row() { printf "${C}%-14s${R}  ${K}%-28s${R}  %s\n" "$1" "$2" "$3"; }

  # Motion
  row "MOTION" "h / j / k / l" "Left / Down / Up / Right"
  row "MOTION" "w / W" "Next word / WORD start"
  row "MOTION" "b / B" "Prev word / WORD start"
  row "MOTION" "e / E" "Next word / WORD end"
  row "MOTION" "ge / gE" "Prev word / WORD end"
  row "MOTION" "0 / ^" "Line start / first non-blank"
  row "MOTION" "\$" "Line end"
  row "MOTION" "gg / G" "File top / bottom"
  row "MOTION" "{N}G" "Go to line N"
  row "MOTION" "{ / }" "Prev / next empty line"
  row "MOTION" "%" "Jump to matching bracket"
  row "MOTION" "H / M / L" "Screen top / middle / bottom"
  row "MOTION" "Ctrl-d / Ctrl-u" "Half page down / up"
  row "MOTION" "Ctrl-f / Ctrl-b" "Full page down / up"
  row "MOTION" "Ctrl-e / Ctrl-y" "Scroll line down / up"
  row "MOTION" "zz / zt / zb" "Center / top / bottom cursor line"
  row "MOTION" "f{c} / F{c}" "Find char forward / backward"
  row "MOTION" "t{c} / T{c}" "To char forward / backward"
  row "MOTION" "; / ," "Repeat f/t forward / backward"
  row "MOTION" "* / #" "Search word under cursor fwd / bwd"
  row "MOTION" "gd / gD" "Go to local / global definition"
  row "MOTION" "gf" "Open file under cursor"
  row "MOTION" "'' / \`\`" "Jump back to last position"

  # Insert Mode
  row "INSERT" "i / I" "Insert before cursor / line start"
  row "INSERT" "a / A" "Append after cursor / line end"
  row "INSERT" "o / O" "New line below / above"
  row "INSERT" "s / S" "Substitute char / entire line"
  row "INSERT" "c{motion}" "Change (delete + enter insert)"
  row "INSERT" "cc / C" "Change line / to end of line"
  row "INSERT" "Esc / Ctrl-c" "Exit insert mode"
  row "INSERT" "Ctrl-w" "Delete word backward"
  row "INSERT" "Ctrl-u" "Delete to line start"
  row "INSERT" "Ctrl-r {reg}" "Paste from register"
  row "INSERT" "Ctrl-t / Ctrl-d" "Indent / de-indent line"
  row "INSERT" "Ctrl-n / Ctrl-p" "Autocomplete next / previous"
  row "INSERT" "Ctrl-x Ctrl-f" "Filename completion"
  row "INSERT" "Ctrl-x Ctrl-l" "Line completion"

  # Visual Mode
  row "VISUAL" "v / V / Ctrl-v" "Char / line / block select"
  row "VISUAL" "o" "Move to other end of selection"
  row "VISUAL" "gv" "Reselect last visual"
  row "VISUAL" "> / <" "Indent / de-indent selection"
  row "VISUAL" "~ / u / U" "Toggle / lower / uppercase"
  row "VISUAL" "= / gq" "Auto-indent / format selection"
  row "VISUAL" "y / d / c" "Yank / delete / change selection"
  row "VISUAL" "I / A" "Insert at block start / end (Ctrl-v)"

  # Operators & Text Objects
  row "OPERATOR" "d{motion}" "Delete"
  row "OPERATOR" "c{motion}" "Change (delete + insert)"
  row "OPERATOR" "y{motion}" "Yank (copy)"
  row "OPERATOR" ">{motion} / <{motion}" "Indent right / left"
  row "OPERATOR" "={motion}" "Auto-indent"
  row "OPERATOR" "g~{motion}" "Toggle case"
  row "OPERATOR" "gu{motion} / gU{motion}" "Lowercase / uppercase"
  row "TEXT OBJ" "iw / aw" "Inner / around word"
  row "TEXT OBJ" "is / as" "Inner / around sentence"
  row "TEXT OBJ" "ip / ap" "Inner / around paragraph"
  row "TEXT OBJ" 'i" / a"' "Inner / around double quotes"
  row "TEXT OBJ" "i' / a'" "Inner / around single quotes"
  row "TEXT OBJ" "i\` / a\`" "Inner / around backticks"
  row "TEXT OBJ" "i) / a)" "Inner / around parentheses"
  row "TEXT OBJ" "i] / a]" "Inner / around brackets"
  row "TEXT OBJ" "i} / a}" "Inner / around braces"
  row "TEXT OBJ" "i> / a>" "Inner / around angle brackets"
  row "TEXT OBJ" "it / at" "Inner / around HTML/XML tag"

  # Delete / Yank / Paste
  row "DELETE" "x / X" "Delete char forward / backward"
  row "DELETE" "dd / D" "Delete line / to end"
  row "DELETE" "dw / db / de" "Delete word fwd / bwd / to end"
  row "DELETE" "diw / daw" "Delete inner / around word"
  row "YANK" "yy / Y" "Yank line"
  row "YANK" "yw / yb" "Yank word fwd / bwd"
  row "PASTE" "p / P" "Paste after / before cursor"
  row "PASTE" '""{reg}p' "Paste from named register"
  row "PASTE" ":reg" "List all registers"
  row "PASTE" "gp / gP" "Paste and move cursor after"

  # Search & Replace
  row "SEARCH" "/{pattern}" "Search forward"
  row "SEARCH" "?{pattern}" "Search backward"
  row "SEARCH" "n / N" "Next / previous match"
  row "SEARCH" ":nohl" "Clear search highlight"
  row "SEARCH" ":%s/old/new/g" "Replace all in file"
  row "SEARCH" ":%s/old/new/gc" "Replace all with confirm"
  row "SEARCH" ":s/old/new/g" "Replace in current line"
  row "SEARCH" ":g/pattern/d" "Delete lines matching pattern"
  row "SEARCH" ":g/pattern/cmd" "Run command on matching lines"
  row "SEARCH" ":v/pattern/d" "Delete non-matching lines"

  # Undo / Redo / Repeat
  row "HISTORY" "u" "Undo"
  row "HISTORY" "Ctrl-r" "Redo"
  row "HISTORY" "." "Repeat last change"
  row "HISTORY" "@:" "Repeat last command-line command"
  row "HISTORY" "{N}u" "Undo N changes"

  # Windows / Splits
  row "SPLITS" "Ctrl-w s / v" "Split horizontal / vertical"
  row "SPLITS" "Ctrl-w h/j/k/l" "Navigate to split"
  row "SPLITS" "Ctrl-w H/J/K/L" "Move split to side"
  row "SPLITS" "Ctrl-w =" "Equalize split sizes"
  row "SPLITS" "Ctrl-w > / <" "Increase / decrease width"
  row "SPLITS" "Ctrl-w + / -" "Increase / decrease height"
  row "SPLITS" "Ctrl-w q / c" "Quit / close split"
  row "SPLITS" "Ctrl-w o" "Close all other splits"
  row "SPLITS" "Ctrl-w r / R" "Rotate splits down / up"
  row "SPLITS" ":sp {file}" "Open file in horiz split"
  row "SPLITS" ":vsp {file}" "Open file in vert split"

  # Tabs
  row "TABS" ":tabnew / :tabe {f}" "New tab / open file in tab"
  row "TABS" "gt / gT" "Next / previous tab"
  row "TABS" "{n}gt" "Go to tab N"
  row "TABS" ":tabclose / :tabc" "Close current tab"
  row "TABS" ":tabonly / :tabo" "Close all other tabs"
  row "TABS" ":tabmove {n}" "Move tab to position N"

  # Buffers
  row "BUFFERS" ":ls / :buffers" "List open buffers"
  row "BUFFERS" ":b {n/name}" "Switch to buffer N or name"
  row "BUFFERS" ":bn / :bp" "Next / previous buffer"
  row "BUFFERS" ":bd" "Close (delete) buffer"
  row "BUFFERS" ":b#" "Switch to alternate buffer"
  row "BUFFERS" ":bufdo {cmd}" "Run command on all buffers"

  # File Commands
  row "FILES" ":e {file}" "Open / edit file"
  row "FILES" ":w" "Write (save) file"
  row "FILES" ":wa" "Write all modified buffers"
  row "FILES" ":q / :q!" "Quit / force quit"
  row "FILES" ":wq / :x / ZZ" "Save and quit"
  row "FILES" ":qa!" "Quit all without saving"
  row "FILES" "ZQ" "Quit without saving"
  row "FILES" ":saveas {file}" "Save to new filename"
  row "FILES" "Ctrl-g" "Show filename & cursor position"
  row "FILES" ":cd {dir}" "Change working directory"
  row "FILES" ":pwd" "Print working directory"

  # Marks
  row "MARKS" "m{a-z}" "Set local mark"
  row "MARKS" "m{A-Z}" "Set global mark (cross-file)"
  row "MARKS" "'{mark}" "Jump to mark line"
  row "MARKS" "\`{mark}" "Jump to mark exact position"
  row "MARKS" ":marks" "List all marks"
  row "MARKS" "\`[ / \`]" "Start / end of last change"
  row "MARKS" "\`< / \`>" "Start / end of last visual"

  # Macros
  row "MACROS" "q{a-z}" "Start recording macro to register"
  row "MACROS" "q" "Stop recording"
  row "MACROS" "@{a-z}" "Play macro from register"
  row "MACROS" "@@" "Replay last macro"
  row "MACROS" "{n}@{a-z}" "Play macro N times"

  # Registers
  row "REGISTERS" '"{a-z}{op}' "Use named register with operator"
  row "REGISTERS" '"+{op}' "System clipboard register"
  row "REGISTERS" '"*{op}' "Primary selection register"
  row "REGISTERS" '"%' "Current filename"
  row "REGISTERS" '".' "Last inserted text"
  row "REGISTERS" '"/' "Last search pattern"
  row "REGISTERS" '":" ' "Last command-line command"
  row "REGISTERS" '"-' "Small delete register"
  row "REGISTERS" '"0' "Last yank (not deleted)"
  row "REGISTERS" '"1-"9' "Recent delete history"

  # Folds
  row "FOLDS" "za / zA" "Toggle fold / recursive"
  row "FOLDS" "zo / zO" "Open fold / recursive"
  row "FOLDS" "zc / zC" "Close fold / recursive"
  row "FOLDS" "zr / zR" "Reduce fold level / open all"
  row "FOLDS" "zm / zM" "Increase fold level / close all"
  row "FOLDS" "zf{motion}" "Create fold (manual foldmethod)"
  row "FOLDS" "zd / zD" "Delete fold / recursive"
  row "FOLDS" "[z / ]z" "Move to fold start / end"

  # Command Mode
  row "CMD MODE" ":" "Enter command mode"
  row "CMD MODE" "Ctrl-r Ctrl-w" "Insert word under cursor"
  row "CMD MODE" "Ctrl-r /" "Insert last search pattern"
  row "CMD MODE" "Ctrl-r {reg}" "Insert register contents"
  row "CMD MODE" "Up / Ctrl-p" "Previous command history"
  row "CMD MODE" "Down / Ctrl-n" "Next command history"
  row "CMD MODE" "Tab" "Command completion"
  row "CMD MODE" "Ctrl-c / Esc" "Cancel / exit command mode"
  row "CMD MODE" ":{range}d" "Delete lines in range"
  row "CMD MODE" ":{range}y" "Yank lines in range"
  row "CMD MODE" ":{range}co {dst}" "Copy lines to destination"
  row "CMD MODE" ":{range}m {dst}" "Move lines to destination"
  row "CMD MODE" ":{range}norm {cmd}" "Run normal command on range"

  # Quickfix
  row "QUICKFIX" ":copen / :cclose" "Open / close quickfix window"
  row "QUICKFIX" ":cn / :cp" "Next / previous item"
  row "QUICKFIX" ":cc {n}" "Jump to item N"
  row "QUICKFIX" ":cfdo {cmd}" "Run command on each qf file"
  row "QUICKFIX" ":lopen / :lclose" "Open / close location list"
  row "QUICKFIX" ":ln / :lp" "Next / prev location item"

  # Misc
  row "MISC" "Ctrl-a / Ctrl-x" "Increment / decrement number"
  row "MISC" "J / gJ" "Join lines with / without space"
  row "MISC" "ga" "Show ASCII / Unicode of char"
  row "MISC" "g8" "Show UTF-8 bytes under cursor"
  row "MISC" "K" "Look up keyword under cursor"
  row "MISC" "Ctrl-l" "Redraw screen"
  row "MISC" "~ / g~{motion}" "Toggle case (char / motion)"
  row "MISC" ":sort" "Sort lines"
  row "MISC" ":sort u" "Sort lines, remove duplicates"
  row "MISC" ":retab" "Convert tabs to spaces (or vice versa)"
  row "MISC" ":%!{cmd}" "Filter buffer through shell command"
  row "MISC" ":r {file}" "Read file contents into buffer"
  row "MISC" ":r !{cmd}" "Read command output into buffer"
}

if [ ! -f "$DATA" ]; then
  mkdir -p "$(dirname "$DATA")"
  generate > "$DATA"
fi

exec setsid uwsm-app -- xdg-terminal-exec \
  --app-id=org.omarchy.nvim-cheatsheet \
  --title="Nvim Cheatsheet" \
  -e /home/njblaga/Omarchy-supplement/bin/nvim-cheatsheet-ui
